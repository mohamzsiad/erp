npm install# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=info

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://erpadmin:erppassword@localhost:5432/clouderp?schema=public"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redispassword@localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=your_very_long_random_jwt_secret_here_change_in_production
JWT_REFRESH_SECRET=your_very_long_random_refresh_secret_here_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM="CloudERP <noreply@clouderp.com>"

# ── Azure Storage (for file attachments) ─────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=your_azure_storage_connection_string
AZURE_BLOB_CONTAINER=erp-attachments

# ── AI (Anthropic) ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Azure Application Insights (optional for dev) ────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=
